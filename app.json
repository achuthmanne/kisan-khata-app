{
  "expo": {
    "name": "Kisan Khata",
    "slug": "agri-snap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "agrisnap",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.achuth.agrisnap",
      "config": {
        "googleMapsApiKey": "AIzaSyCpd2HMnvu531V6S-6cx1jtArXmCh2KBcY"
      },
      "infoPlist": {
        "NSMicrophoneUsageDescription": "రైతులకు వాయిస్ సెర్చ్ కోసం మైక్రోఫోన్ అనుమతి అవసరం.",
        "NSSpeechRecognitionUsageDescription": "వాయిస్ కమాండ్స్ ద్వారా యంత్రాలను వెతకడానికి అనుమతి ఇవ్వండి.",
        "NSContactsUsageDescription": "రైతులు, మేస్త్రీలు లేదా డ్రైవర్ల పేర్లు మరియు ఫోన్ నంబర్లను మీ కాంటాక్ట్స్ నుండి సులభంగా ఎంచుకోవడానికి ఈ అనుమతి అవసరం."
      }
    },
    "android": {
      "versionCode": 3,
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/logo.png"
      },
      "package": "com.achuth.agrisnap",
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCpd2HMnvu531V6S-6cx1jtArXmCh2KBcY"
        }
      },
      "permissions": [
        "INTERNET",
        "RECORD_AUDIO",
        "CAMERA",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "READ_CONTACTS",
        "SCHEDULE_EXACT_ALARM",
        "USE_EXACT_ALARM",
        "WAKE_LOCK",
        "DISABLE_KEYGUARD",
        "VIBRATE",
        "SYSTEM_ALERT_WINDOW",
        "RECEIVE_BOOT_COMPLETED",
        "USE_FULL_SCREEN_INTENT"
      ],
      "blockedPermissions": []
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "./withManifestFix.js",
      "./withAlarmSound.js",
      "./withLockScreenBypass.js",
      "./withNotifeeMaven.js",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      "expo-font",
      "@react-native-community/datetimepicker",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "రైతులకు వాయిస్ సెర్చ్ కోసం మైక్రోఫోన్ అనుమతి అవసరం."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "మీ రైతులు మరియు డ్రైవర్లను సులభంగా యాడ్ చేయడానికి కాంటాక్ట్స్ పర్మిషన్ అవసరం."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo.png",
          "color": "#1B5E20"
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3a4c40e8-8a05-4e80-8f28-97d2c7414ac3"
      }
    },
    "owner": "achuthmanne"
  }
}
