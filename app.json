{
  "expo": {
    "name": "Agrisnap",
    "slug": "agri-snap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "agrisnap",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.achuth.agrisnap",
      "config": {
        "googleMapsApiKey": "AIzaSyCpd2HMnvu531V6S-6cx1jtArXmCh2KBcY"
      },
      "infoPlist": {
        "NSMicrophoneUsageDescription": "రైతులకు వాయిస్ సెర్చ్ కోసం మైక్రోఫోన్ అనుమతి అవసరం.",
        "NSSpeechRecognitionUsageDescription": "వాయిస్ కమాండ్స్ ద్వారా యంత్రాలను వెతకడానికి అనుమతి ఇవ్వండి.",
        "NSContactsUsageDescription": "రైతులు, మేస్త్రీలు లేదా డ్రైవర్ల పేర్లు మరియు ఫోన్ నంబర్లను మీ కాంటాక్ట్స్ నుండి సులభంగా ఎంచుకోవడానికి ఈ అనుమతి అవసరం."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1B5E20",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.achuth.agrisnap",
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCpd2HMnvu531V6S-6cx1jtArXmCh2KBcY"
        }
      },
      "permissions": [
        "INTERNET",
        "RECORD_AUDIO",
        "CAMERA",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "READ_CONTACTS"
      ],
      "blockedPermissions": []
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#1B5E20"
        }
      ],
      "expo-font",
      "@react-native-community/datetimepicker",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "రైతులకు వాయిస్ సెర్చ్ కోసం మైక్రోఫోన్ అనుమతి అవసరం."
        }
      ],
      "expo-contacts"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3a4c40e8-8a05-4e80-8f28-97d2c7414ac3"
      }
    },
    "owner": "achuthmanne"
  }
}